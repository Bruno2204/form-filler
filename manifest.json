{
  "manifest_version": 3,
  "name": "Form Filler",
  "version": "1.0",
  "description": "Rellena formularios Google",
  "permissions": ["activeTab", "scripting", "sidePanel", "clipboardRead"],
  "host_permissions": ["https://docs.google.com/forms/*"],
  "action": {},
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://docs.google.com/forms/*"],
      "js": [
        "content/constants.js",
        "content/utils.js",
        "content/helpers.js",
        "content/fillPage1.js",
        "content/fillPage2.js",
        "content/fillPage3.js",
        "content/index.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
