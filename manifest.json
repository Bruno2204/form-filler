{
  "manifest_version": 3,
  "name": "Form Filler",
  "version": "1.0",
  "description": "Rellena formularios Google",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://docs.google.com/forms/*"],
      "js": ["floating-button.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["popup.html", "parser.js", "popup.js"],
      "matches": ["https://docs.google.com/forms/*"]
    }
  ]
}
