{
  "manifest_version": 3,
  "name": "Form Filler",
  "version": "1.0",
  "description": "Rellena formularios Google",
  "permissions": ["activeTab", "scripting", "sidePanel", "clipboardRead"],
  "host_permissions": ["https://docs.google.com/forms/*"],
  "action": {},
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://docs.google.com/forms/*"],
      "js": ["content/index.js"],
      "type": "module",
      "run_at": "document_idle"
    }
  ]
}
